graph TD
    %% High-Level Git Object Model - At a Glance
    %% Direction: Top-level concepts flow downward

    C["📝 Commit<br/><small>Snapshot pointer + metadata</small>"] --> T["🌳 Tree<br/><small>Directory listing</small>"]
    T --> B["📄 Blob<br/><small>File content</small>"]
    T --> T2["🌳 Sub-Tree<br/><small>Subdirectory</small>"]
    T2 --> B2["📄 Blob<br/><small>Nested file content</small>"]

    C -.->|"parent"| C_OLD["📝 Parent Commit<br/><small>Previous snapshot</small>"]
    C_OLD --> T_OLD["🌳 Tree"]

    R["🏷️ Refs (HEAD, main, tags)<br/><small>Human-readable pointers</small>"] -.-> C

    %% Styling with strict node-first declaration
    style C fill:#e1f5fe,stroke:#01579b,stroke-width:2px,color:#000
    style T fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000
    style T2 fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000
    style B fill:#fff3e0,stroke:#ef6c00,stroke-width:2px,color:#000
    style B2 fill:#fff3e0,stroke:#ef6c00,stroke-width:2px,color:#000
    style C_OLD fill:#f5f5f5,stroke:#757575,stroke-width:1px,color:#757575
    style T_OLD fill:#f5f5f5,stroke:#757575,stroke-width:1px,color:#757575
    style R fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,color:#000
