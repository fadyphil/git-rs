flowchart TD
    %% Complete Data Flow: Working Directory → Commit

    subgraph "Stage 1: Working Directory"
        WD["Working Directory<br/>Modified files"]
    end

    subgraph "Stage 2: Index / Staging Area"
        INDEX["Index (Staging Area)<br/>─────────────────<br/>tracked: README.md<br/>tracked: src/main.rs<br/>mode: 100644<br/>sha: a1b2c3d..."]
    end

    subgraph "Stage 3: Object Creation"
        ADD["git add<br/>─────────────────<br/>1. Hash file → blob<br/>2. Store blob in .git/objects/<br/>3. Update index entry"]
        WRITE_TREE["git write-tree<br/>─────────────────<br/>1. Read index<br/>2. Create tree from entries<br/>3. Recurse for subdirs<br/>4. Store tree → return hash"]
    end

    subgraph "Stage 4: Commit Creation"
        COMMIT_TREE["git commit-tree<br/>─────────────────<br/>1. Tree hash (from write-tree)<br/>2. Parent commit hash<br/>3. Author + timestamp<br/>4. Commit message<br/>5. Store commit → return hash"]
    end

    subgraph "Stage 5: Reference Update"
        UPDATE_REF["update-ref<br/>─────────────────<br/>Move branch pointer<br/>to new commit hash"]
        HEAD_REF["HEAD → main<br/>now points to new commit"]
    end

    WD -->|"git add file"| ADD
    ADD -->|"updates"| INDEX
    INDEX -->|"git write-tree"| WRITE_TREE
    WRITE_TREE -->|"returns tree hash"| COMMIT_TREE
    COMMIT_TREE -->|"returns commit hash"| UPDATE_REF
    UPDATE_REF --> HEAD_REF

    style WD fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#000
    style INDEX fill:#fff3e0,stroke:#ef6c00,stroke-width:2px,color:#000
    style ADD fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000
    style WRITE_TREE fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000
    style COMMIT_TREE fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000
    style UPDATE_REF fill:#ffebee,stroke:#c62828,stroke-width:2px,color:#000
    style HEAD_REF fill:#ffebee,stroke:#c62828,stroke-width:3px,color:#000
