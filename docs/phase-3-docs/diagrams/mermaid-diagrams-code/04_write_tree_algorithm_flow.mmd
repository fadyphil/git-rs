    style SORT fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#000
    style INIT_BUF fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#000
    style GET_FIRST fill:#fff3e0,stroke:#ef6c00,stroke-width:2px,color:#000
    style CHECK_TYPE fill:#fff9c4,stroke:#f9a825,stroke-width:3px,color:#000
    style HASH_BLOB fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000
    style RECURSE fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000
    style TREE_HASH fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,color:#000
